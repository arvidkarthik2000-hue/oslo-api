# OSLO API Environment Variables
# Copy to .env and fill in real values

# App
ENVIRONMENT=development
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/oslo

# JWT
JWT_SECRET_KEY=CHANGE-ME-IN-PRODUCTION

# MSG91 OTP
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=

# AWS
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=oslo-docs-mumbai
KMS_MASTER_KEY_ID=

# AI Service
AI_SERVICE_BASE_URL=https://oslo-ai.example.com
AI_SERVICE_API_KEY=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Sentry
SENTRY_DSN=
